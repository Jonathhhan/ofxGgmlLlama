# Create a Codex-facing Ollama tag with enough context for tool schemas,
# repository snippets, and agent history:
#
#   ollama create hermes3-codex-32k -f ollama-codex.Modelfile.example
#
# Then launch with:
#
#   scripts\run-example.bat codex -CodexProvider ollama -ServerModel hermes3-codex-32k:latest

FROM hermes3:latest

PARAMETER num_ctx 32768
PARAMETER temperature 0.15
PARAMETER top_p 0.85
